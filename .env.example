# Postgres
POSTGRES_DB=wiki
POSTGRES_USER=wiki
POSTGRES_PASSWORD=wiki
# Host-side port mapping (inside Docker the port is always 5432; host uses 5544
# to avoid conflict with any system-installed postgres on 5432).
POSTGRES_HOST_PORT=5544

# Kafka
KAFKA_TOPIC=wiki.edits
# In-cluster bootstrap is kafka:9092; from host use localhost:9094
KAFKA_BOOTSTRAP_SERVERS=localhost:9094

# Logging
LOG_LEVEL=INFO

# Producer cap (stops after publishing this many edits). 0 = unlimited.
# Default keeps demo data manageable; assignment requires only ≥10k batch records.
MAX_EVENTS_PUBLISHED=100000

# Spark memory (laptop-friendly defaults)
SPARK_DRIVER_MEMORY=2g
BATCH_DRIVER_MEMORY=4g

# Clickstream batch
CLICKSTREAM_PATH=./data/clickstream
CLICKSTREAM_MONTH=2026-04
CLICKSTREAM_LANG=en
